# Integrated WSL development environment for MoneyPlanner SaaS + Core submodule.
# Copy to .env.dev and use with:
# docker compose -f docker-compose.dev.yml --env-file .env.dev up --build -d

# Shared auth and linking
JWT_SIGNING_KEY=dev-only-not-for-production-change-me-please-32b
CORE_LINKING_SHARED_SECRET=dev-only-shared-linking-secret-32b-minimum
CORE_LINKING_TOKEN_MAX_AGE_SECONDS=300
JWT_ISSUER=moneyplanner-saas
JWT_AUDIENCE=moneyplanner-saas-api
AUTH_ACCEPT_EXTERNAL_TOKENS=1
EXTERNAL_JWT_ISSUER=moneyplanner-saas
EXTERNAL_JWT_AUDIENCE=moneyplanner-saas-api
EXTERNAL_JWT_SIGNING_KEY=dev-only-not-for-production-change-me-please-32b

# Core backend
CORE_DJANGO_SECRET_KEY=dev-only-not-for-production-change-me-please-32b
CORE_DJANGO_DEBUG=1
CORE_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,core_backend
CORE_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Core database
CORE_POSTGRES_DB=core
CORE_POSTGRES_USER=core
CORE_POSTGRES_PASSWORD=core

# Core seeding and sync
CORE_SEED_CREATE_ADMIN=1
CORE_SEED_ADMIN_USERNAME=admin
CORE_SEED_ADMIN_EMAIL=admin@example.com
CORE_SEED_ADMIN_PASSWORD=admin
CORE_SEED_FORCE_ADMIN_PASSWORD=0
CORE_SEED_CREATE_DEMO=1
FX_PIVOT=USD
FX_SYNC_ENABLED=1
FX_SYNC_QUOTE_CURRENCY=EUR
FX_SYNC_INTERVAL_SECONDS=86400

# SaaS backend
SAAS_DJANGO_SECRET_KEY=dev-only-not-for-production-change-me-please-32b
SAAS_DJANGO_DEBUG=1
SAAS_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,saas_backend
SAAS_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
SAAS_CORS_ALLOW_CREDENTIALS=0
SAAS_CORS_ALLOW_ALL_ORIGINS=0
CORE_API_BASE_URL=http://core_backend:8000
CORE_API_HOST_HEADER=localhost
CORE_API_X_FORWARDED_PROTO=
CORE_BOOTSTRAP_TIMEOUT_SECONDS=5
SAAS_PUBLIC_REGISTRATION_ENABLED=1
ACCOUNT_LINKING_ENABLED=1

# SaaS database
SAAS_POSTGRES_DB=saas
SAAS_POSTGRES_USER=saas
SAAS_POSTGRES_PASSWORD=saas

# SaaS seeding
SAAS_SEED_CREATE_ADMIN=1
SAAS_SEED_ADMIN_USERNAME=admin
SAAS_SEED_ADMIN_EMAIL=admin@example.com
SAAS_SEED_ADMIN_PASSWORD=admin
SAAS_SEED_FORCE_ADMIN_PASSWORD=0

# Frontends
CORE_FRONTEND_VITE_API_BASE_URL=http://127.0.0.1:8000
CORE_FRONTEND_VITE_CORE_API_BASE_URL=http://127.0.0.1:8000
SAAS_FRONTEND_VITE_API_BASE_URL=http://127.0.0.1:8001
SAAS_FRONTEND_VITE_CORE_API_BASE_URL=http://127.0.0.1:8000

# Optional WSL polling override
FRONTEND_USE_POLLING=false
FRONTEND_POLLING_INTERVAL=300

# Optional broker integrations for Core
PIONEX_API_KEY=
PIONEX_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BROKER_ENCRYPTION_KEY=
