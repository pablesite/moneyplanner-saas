# Desarrollo local desde Docker SaaS hacia Core publicado en el host.
# En produccion usar la URL interna/publica real de Core y dejar CORE_API_HOST_HEADER vacio
# salvo que haya un proxy inverso que requiera forzarlo explicitamente.
CORE_API_BASE_URL=http://host.docker.internal:8000
CORE_API_HOST_HEADER=localhost

SEED_CREATE_ADMIN=1
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin
SEED_FORCE_ADMIN_PASSWORD=0
