DJANGO_SECRET_KEY=dev-only-not-for-production-change-me-please-32b
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=0
CORS_ALLOW_ALL_ORIGINS=0
JWT_SIGNING_KEY=dev-only-not-for-production-change-me-please-32b
